# PostgreSQL
DATABASE_URL=postgresql://incident_user:sua_senha@localhost:5432/incident_security

JWT_SECRET=altere_para_um_segredo_longo_e_aleatorio

# URLs (MVC: frontend :5173, backend :3000)
PORT=3000
FRONTEND_URL=http://localhost:5173
VITE_API_PROXY_TARGET=http://localhost:3000

# App / OAuth (local: use estes valores; produção: ajuste conforme provedor)
VITE_APP_ID=local
OAUTH_SERVER_URL=http://localhost:3000
VITE_OAUTH_PORTAL_URL=http://localhost:5173/login
OWNER_OPEN_ID=local_admin
OWNER_NAME=Administrador

# Analytics Umami (opcional — deixe vazio para desativar)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Serviços ML (opcional — padrão local)
ML_SERVICE_URL=http://localhost:5001

# Notificações externas (opcional)
# BUILT_IN_FORGE_API_URL=http://localhost:3000/api
# BUILT_IN_FORGE_API_KEY=local_key

# SIEM / Wazuh — integração MVP
SIEM_ENABLED=true
WAZUH_DELIVERY=syslog
WAZUH_SYSLOG_HOST=10.208.1.229
WAZUH_SYSLOG_PORT=514
# Alternativa local (sem syslog): WAZUH_DELIVERY=file e WAZUH_LOG_PATH=./data/siem/events.ndjson
