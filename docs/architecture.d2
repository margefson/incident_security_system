direction: right

vars: {
  d2-config: {
    layout-engine: elk
  }
}

# ── USUÁRIO ──────────────────────────────────────────────────────────────────
user: "👤 Usuário / Analista SOC" {
  shape: person
  style: {
    fill: "#1c2128"
    stroke: "#58a6ff"
    font-color: "#e6edf3"
    font-size: 14
    bold: true
  }
}

# ── FRONTEND ─────────────────────────────────────────────────────────────────
frontend: "🖥  FRONTEND — React 19 + Vite" {
  style: {
    fill: "#0d1117"
    stroke: "#1f6feb"
    font-color: "#58a6ff"
    bold: true
    font-size: 15
  }

  pages: "Páginas React" {
    style: { fill: "#161b22"; stroke: "#1f6feb"; font-color: "#79c0ff" }
    p1: "Dashboard"
    p2: "Incidentes (filtros avançados + CSV)"
    p3: "Análise de Risco"
    p4: "Painel Admin (stats globais)"
    p5: "Perfil (/profile)"
    p6: "Login / Registro"
  }

  ui: "UI Stack" {
    style: { fill: "#161b22"; stroke: "#1f6feb"; font-color: "#79c0ff" }
    u1: "shadcn/ui"
    u2: "Tailwind CSS 4 (OKLCH dark)"
    u3: "Recharts (gráficos)"
    u4: "Wouter (roteamento)"
  }

  trpc_client: "tRPC Client (superjson)" {
    style: { fill: "#1c2128"; stroke: "#58a6ff"; font-color: "#58a6ff"; bold: true }
  }
}

# ── BACKEND ───────────────────────────────────────────────────────────────────
backend: "⚙  BACKEND — Node.js 22 + Express 4 (porta 3000)" {
  style: {
    fill: "#0d1117"
    stroke: "#3fb950"
    font-color: "#3fb950"
    bold: true
    font-size: 15
  }

  trpc_server: "tRPC Server" {
    style: { fill: "#1c2128"; stroke: "#3fb950"; font-color: "#3fb950"; bold: true }
  }

  routers: "Routers tRPC" {
    style: { fill: "#161b22"; stroke: "#3fb950"; font-color: "#56d364" }
    r1: "authRouter\n(register / login / logout / me)"
    r2: "incidentsRouter\n(CRUD + stats + riskAnalysis)"
    r3: "categoriesRouter\n(CRUD — admin only)"
    r4: "adminRouter\n(global + ML metrics + users)"
    r5: "reportsRouter\n(exportPdf — user + admin mode)"
  }

  security: "Segurança" {
    style: { fill: "#161b22"; stroke: "#f78166"; font-color: "#ffa198" }
    s1: "Helmet (HTTP headers)"
    s2: "CORS (origem controlada)"
    s3: "Rate Limiting (100 req/15min)"
    s4: "bcrypt custo 12"
    s5: "JWT HttpOnly (sessão)"
    s6: "Timing-attack protection"
  }

  orm: "Drizzle ORM" {
    style: { fill: "#1c2128"; stroke: "#3fb950"; font-color: "#3fb950"; bold: true }
  }
}

# ── BANCO DE DADOS ────────────────────────────────────────────────────────────
db: "🗄  BANCO DE DADOS — TiDB / MySQL 8" {
  style: {
    fill: "#0d1117"
    stroke: "#d29922"
    font-color: "#d29922"
    bold: true
    font-size: 15
  }

  t1: "users\n(id, name, email, passwordHash, role)" {
    style: { fill: "#161b22"; stroke: "#d29922"; font-color: "#e3b341" }
  }
  t2: "incidents\n(id, userId, title, category,\nriskLevel, confidence)" {
    style: { fill: "#161b22"; stroke: "#d29922"; font-color: "#e3b341" }
  }
  t3: "categories\n(id, name, description, color, isActive)" {
    style: { fill: "#161b22"; stroke: "#d29922"; font-color: "#e3b341" }
  }
}

# ── ML SERVICE ────────────────────────────────────────────────────────────────
ml: "🤖  ML SERVICE — Python Flask (porta 5001)" {
  style: {
    fill: "#0d1117"
    stroke: "#bc8cff"
    font-color: "#bc8cff"
    bold: true
    font-size: 15
  }

  model: "TF-IDF + Naive Bayes\n(acurácia 97% — CV 5-fold)" {
    style: { fill: "#1c2128"; stroke: "#bc8cff"; font-color: "#d2a8ff"; bold: true }
  }

  ep1: "POST /classify\n→ categoria + confiança" {
    style: { fill: "#161b22"; stroke: "#bc8cff"; font-color: "#d2a8ff" }
  }
  ep2: "GET /metrics\n→ acurácia + relatório" {
    style: { fill: "#161b22"; stroke: "#bc8cff"; font-color: "#d2a8ff" }
  }
  ep3: "POST /retrain\n→ retreinar com novas amostras" {
    style: { fill: "#161b22"; stroke: "#bc8cff"; font-color: "#d2a8ff" }
  }
  ep4: "GET /dataset\n→ download xlsx" {
    style: { fill: "#161b22"; stroke: "#bc8cff"; font-color: "#d2a8ff" }
  }

  dataset: "Dataset\n(100 amostras — xlsx)" {
    style: { fill: "#1c2128"; stroke: "#bc8cff"; font-color: "#d2a8ff" }
  }
}

# ── PDF SERVICE ───────────────────────────────────────────────────────────────
pdf: "📄  PDF SERVICE — Python Flask (porta 5002)" {
  style: {
    fill: "#0d1117"
    stroke: "#f78166"
    font-color: "#f78166"
    bold: true
    font-size: 15
  }

  reportlab: "ReportLab\n(geração de PDF)" {
    style: { fill: "#161b22"; stroke: "#f78166"; font-color: "#ffa198" }
  }
  ep_pdf: "POST /generate-pdf\n→ relatório (user + admin mode)" {
    style: { fill: "#161b22"; stroke: "#f78166"; font-color: "#ffa198" }
  }
}

# ── CONEXÕES ──────────────────────────────────────────────────────────────────

user -> frontend.trpc_client: "HTTPS" {
  style: { stroke: "#58a6ff"; font-color: "#58a6ff" }
}

frontend.trpc_client -> backend.trpc_server: "tRPC / HTTP\n(superjson)" {
  style: { stroke: "#3fb950"; font-color: "#3fb950"; bold: true }
}

backend.trpc_server -> backend.routers
backend.routers -> backend.security
backend.orm -> db: "SQL (TLS)" {
  style: { stroke: "#d29922"; font-color: "#d29922" }
}

backend.routers.r2 -> ml.ep1: "POST /classify" {
  style: { stroke: "#bc8cff"; font-color: "#bc8cff" }
}
backend.routers.r4 -> ml.ep2: "GET /metrics" {
  style: { stroke: "#bc8cff"; font-color: "#bc8cff" }
}
backend.routers.r4 -> ml.ep3: "POST /retrain" {
  style: { stroke: "#bc8cff"; font-color: "#bc8cff" }
}
backend.routers.r4 -> ml.ep4: "GET /dataset" {
  style: { stroke: "#bc8cff"; font-color: "#bc8cff" }
}

backend.routers.r5 -> pdf.ep_pdf: "POST /generate-pdf" {
  style: { stroke: "#f78166"; font-color: "#f78166" }
}

ml.model -> ml.dataset: "treina com"
